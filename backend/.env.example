# LLM Provider (Swap 'groq' for 'openai' or 'anthropic' later)
# LLM_PROVIDER=groq
LLM_PROVIDER=nvidia
# GROQ_API_KEY=gsk_your_groq_api_key_here
NVIDIA_API_KEY=nvapi_your_nvidia_api_key_here
# LLM_MODEL=groq/llama-3.1-8b-instant
LLM_MODEL=meta/llama-3.1-405b-instruct

# Vector DB (Qdrant)
QDRANT_URL=https://your-qdrant-cluster.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_END_POINT=https://your-qdrant-cluster.qdrant.io:6333

# Graph DB (Neo4j)
NEO4J_URI=neo4j+s://your-databases.neo4j.io
NEO4J_USERNAME=your_neo4j_username
NEO4J_PASSWORD=your_neo4j_password

# Data Sources
GITHUB_TOKEN=ghp_your_github_token_here

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE=logs/app.log

# Langsmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=lsv2_pt_your_langchain_api_key_here
LANGCHAIN_PROJECT="support-engineer"

# ── Auth0 ─
AUTH_ENABLED=T
AUTH0_DOMAIN=your-auth0-domain.us.auth0.com
AUTH0_AUDIENCE=https://api.support-engineer

# Webhook
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_SESSION_ID=your_webhook_session_id_here


# ── Redis (Upstash) ─
# Create at https://upstash.com (free tier, no credit card)
REDIS_URL=redis url
